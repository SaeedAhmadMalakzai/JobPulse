# Copy this file to .env and fill in your own values.
# NEVER commit .env or any file containing real passwords, API keys, or personal data.
# See SECURITY.md and README for details.

# === Email: SEND applications (SMTP) ===
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-application-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_NAME=Your Name

# === Email: RECEIVE alerts (job responses) ===
ALERT_EMAIL=your-email@example.com

# === IMAP: same inbox (to detect job responses) ===
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=your-application-email@gmail.com
IMAP_PASSWORD=your-app-password

# === Paths (relative to project root or absolute) ===
CV_PATH=cv.pdf
COVER_LETTER_PATH=

# === Applicant details (for form filling and cover letter signature) ===
FIRST_NAME=
MIDDLE_NAME=
LAST_NAME=
FULL_NAME=
SALUTATION=Mr
GENDER=Male
PHONE_COUNTRY_CODE=+1
PHONE_NUMBER=
COUNTRY=
CITY=
YEARS_EXPERIENCE=5
LINKEDIN_PROFILE_URL=https://www.linkedin.com/in/yourprofile/
SUBMISSION_EMAIL=your-application-email@example.com
SUBMISSION_EMAIL_PASSWORD=

# === Cover letter bio (optional; used in generated letters) ===
COVER_LETTER_UNIVERSITY=
COVER_LETTER_PREVIOUS_ORGANIZATION=

# === Max job age in days (skip jobs older than this) ===
MAX_JOB_AGE_DAYS=30

# === Portal credentials (set only the ones you use) ===
JOBS_AF_EMAIL=
JOBS_AF_PASSWORD=

ACBAR_EMAIL=
ACBAR_PASSWORD=

WAZIFAHA_EMAIL=
WAZIFAHA_PASSWORD=

HADAF_EMAIL=
HADAF_PASSWORD=

LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=
# LINKEDIN_STATE_PATH=data/linkedin_state.json
# LINKEDIN_HEADLESS=true
# LINKEDIN_EASY_APPLY_ONLY=false
# LINKEDIN_LOCATION=
# LINKEDIN_GEO_ID=
# LINKEDIN_INCLUDE_GLOBAL_REMOTE_SEARCH=true
# LINKEDIN_DEBUG_ARTIFACTS=true
# LINKEDIN_APPLY_TIMEOUT_SEC=180
# LINKEDIN_DISCOVERY_MAX_PAGES=5
# LINKEDIN_DISCOVERY_MAX_JOBS_PER_SEARCH=150

# === Scope policy ===
# APPLY_LOCAL_FIRST=true
# APPLY_GLOBAL_REMOTE=true
# APPLY_OTHER_REGIONS=false
# APPLY_ATTEMPT_TIMEOUT_SEC=120

# === Job filter keywords (comma-separated; IT is matched case-sensitively) ===
JOB_KEYWORDS=software,developer,engineer,analyst,data,IT,technology,devops,cloud,security,network,mobile,QA,test,manager,specialist,officer,consultant,project,scrum,frontend,backend,full stack,database,systems,architect,automation,machine learning,AI,ML
JOB_EXCLUDE_KEYWORDS=

# === Optional: CAPTCHA solving (e.g. 2Captcha) ===
# CAPTCHA_API_KEY=

# === Optional: run only these adapters (comma-separated names) ===
# ADAPTERS=linkedin,jobs_af,acbar
